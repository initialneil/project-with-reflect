{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh .codex/hooks/project-with-reflect.sh userprompt || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh .codex/hooks/project-with-reflect.sh pretool || true",
            "statusMessage": "Checking PWR memory"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh .codex/hooks/project-with-reflect.sh posttool || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh .codex/hooks/project-with-reflect.sh postwrite || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh .codex/hooks/project-with-reflect.sh precompact || true",
            "statusMessage": "Preparing PWR memory"
          }
        ]
      }
    ]
  }
}
